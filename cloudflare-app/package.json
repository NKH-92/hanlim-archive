{
  "name": "hanlim-archive-cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "check": "node scripts/check-syntax.mjs",
    "typecheck": "tsc -p jsconfig.check.json",
    "lint": "eslint . --max-warnings 0",
    "format:check": "node scripts/check-format.mjs",
    "check:migrations": "node scripts/check-migrations.mjs",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage",
    "verify": "npm run check && npm run typecheck && npm run lint && npm run format:check && npm run check:migrations && npm test",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply hanlim-archive --local",
    "db:migrate:remote": "wrangler d1 migrations apply hanlim-archive --remote"
  },
  "devDependencies": {
    "eslint": "10.7.0",
    "typescript": "7.0.2",
    "wrangler": "^4.13.2"
  }
}
